rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Signatures — public (signers have no account) ─────────────────────────
    match /signatures/{docId} {
      allow read, write: if true;
    }

    // ── Trips ─────────────────────────────────────────────────────────────────
    function isMember(tripId) {
      let trip = get(/databases/$(database)/documents/trips/$(tripId)).data;
      return request.auth != null && (
        trip.ownerUid == request.auth.uid ||
        request.auth.uid in trip.collaborators
      );
    }

    match /trips/{tripId} {
      // Any authenticated user can read trips
      // (trip IDs are UUIDs; invite token is required to discover a trip)
      allow read: if request.auth != null;

      // Only the creator can create (and must set themselves as owner)
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;

      // Owner or collaborator can update
      // Exception: any authenticated user can add themselves to collaborators (join via invite)
      allow update: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        request.auth.uid in resource.data.collaborators ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["collaborators", "updatedAt"]) &&
          request.auth.uid in request.resource.data.collaborators
        )
      );

      // Only the owner can delete
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;

      // Subcollections (students, staff, appendices) — owner or collaborator only
      match /{subcollection}/{docId} {
        allow read, write: if isMember(tripId);
      }
    }
  }
}
