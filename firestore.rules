rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Signatures ────────────────────────────────────────────────────────────
    // Public read (signers have no account).
    // Write is restricted: only allowed when status is "pending" and not expired,
    // and only the signature/status/signedAt fields may be changed.
    match /signatures/{docId} {
      allow read: if true;

      // Initial creation — allowed from the app (trip owner sets up the request)
      allow create: if true;

      // Submission — signer updates signature + status only, while still pending and not expired
      allow update: if
        resource.data.status == "pending" &&
        request.time < resource.data.expiresAt &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["signature", "status", "signedAt"]) &&
        request.resource.data.status == "signed" &&
        request.resource.data.signature is string &&
        request.resource.data.signature.size() < 300000;

      allow delete: if false;
    }

    // ── Trips ─────────────────────────────────────────────────────────────────
    function isMember(tripId) {
      let trip = get(/databases/$(database)/documents/trips/$(tripId)).data;
      return request.auth != null && (
        trip.ownerUid == request.auth.uid ||
        request.auth.uid in trip.collaborators
      );
    }

    match /trips/{tripId} {
      // Only members can read their own trips
      allow read: if isMember(tripId);

      // Only the creator can create (and must set themselves as owner)
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;

      // Owner or collaborator can update.
      // Exception: any authenticated user can add themselves to collaborators (join via invite link).
      allow update: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        request.auth.uid in resource.data.collaborators ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["collaborators", "updatedAt"]) &&
          request.auth.uid in request.resource.data.collaborators
        )
      );

      // Only the owner can delete
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;

      // Subcollections (students, staff, appendices) — owner or collaborator only
      match /{subcollection}/{docId} {
        allow read, write: if isMember(tripId);
      }
    }
  }
}
