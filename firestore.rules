rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Signatures ────────────────────────────────────────────────────────────
    match /signatures/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if
        // Authenticated trip member resending / resetting the request
        isMember(resource.data.tripId) ||
        // Public signer submitting their signature (no auth required)
        (
          resource.data.status == "pending" &&
          request.time < resource.data.expiresAt &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["signature", "status", "signedAt"]) &&
          request.resource.data.status == "signed" &&
          request.resource.data.signature is string &&
          request.resource.data.signature.size() < 300000
        );
      allow delete: if false;
    }

    // ── Class tokens (teacher edit links) ────────────────────────────────────
    match /classTokens/{token} {
      allow read: if true;   // public — needed by teacher edit page
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // ── Room-fill tokens (teacher room assignment links) ─────────────────────
    match /roomFillTokens/{token} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // ── Invite token reverse lookup ───────────────────────────────────────────
    // Public read so non-members can resolve a tripId from an invite token
    // without querying the protected trips collection.
    match /inviteTokens/{token} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // ── Trips ─────────────────────────────────────────────────────────────────

    // For reads: check ownership directly on the document being read (no get() needed)
    function canReadTrip(tripData) {
      return request.auth != null && (
        tripData.ownerUid == request.auth.uid ||
        request.auth.uid in tripData.collaborators
      );
    }

    // For subcollections: must call get() since we only have tripId
    function isMember(tripId) {
      let trip = get(/databases/$(database)/documents/trips/$(tripId)).data;
      return request.auth != null && (
        trip.ownerUid == request.auth.uid ||
        request.auth.uid in trip.collaborators
      );
    }

    match /trips/{tripId} {
      allow read:   if canReadTrip(resource.data);
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        request.auth.uid in resource.data.collaborators ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["collaborators", "updatedAt"]) &&
          request.auth.uid in request.resource.data.collaborators
        )
      );
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;

      match /{subcollection}/{docId} {
        allow read, write: if isMember(tripId);
      }

      // Students: readable without auth so teachers with a class token link can
      // load their class list. TripId is a UUID — not guessable. Writes still
      // require trip membership (the generic subcollection rule above applies).
      match /students/{studentId} {
        allow read: if true;
      }

      // Pending updates: teachers write publicly (token validated client-side);
      // trip members can read and update status (approve/reject).
      match /pendingUpdates/{updateId} {
        allow create: if
          request.resource.data.status == "pending" && (
            exists(/databases/$(database)/documents/classTokens/$(request.resource.data.token)) ||
            exists(/databases/$(database)/documents/roomFillTokens/$(request.resource.data.token))
          );
        allow read, update: if isMember(tripId);
      }
    }
  }
}
